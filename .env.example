# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored — never commit real secrets.

# Signs the session JWT. Generate one with:  openssl rand -base64 33
# (or: npx auth secret)
AUTH_SECRET=

# Google OAuth 2.0 credentials from Google Cloud Console
# (APIs & Services → Credentials → OAuth client ID → "Web application").
# Authorized redirect URIs to add there:
#   http://localhost:3000/api/auth/callback/google
#   https://YOUR-VERCEL-DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Required on Vercel (and behind any proxy) so Auth.js trusts the host header.
AUTH_TRUST_HOST=true

# --- Optional: turn on analytics / conversion tracking later ---
# Set to your GA4 Measurement ID (e.g. G-XXXXXXXXXX) to load Google Analytics.
# Leaving it blank keeps the app tracking-free.
# NEXT_PUBLIC_GA_ID=
